import xarray as xr
import numpy as np
import matplotlib.pyplot as plt
import cartopy.crs as ccrs
import cartopy.feature as cfeature

# =============================
# 1. Settings
# =============================

year = 2000

sst_folder = r"C:/Users/Aina Ajibola/Desktop/oisst_data"
p90_file = r"C:/Users/Aina Ajibola/Desktop/P90_1981-2010/threshold.nc"

# =============================
# 2. Load SST and P90
# =============================

print("Loading SST files...")

sst_ds = xr.open_mfdataset(
    f"{sst_folder}/{year}*.nc",
    combine="by_coords"
)

p90_ds = xr.open_dataset(p90_file)

print("Files loaded.")

# =============================
# 3. Extract variables and remove zlev
# =============================

sst = sst_ds["sst"].isel(zlev=0, drop=True)
p90 = p90_ds["p90_threshold"].isel(zlev=0, drop=True)

# =============================
# 4. Match SST region to P90 grid
# =============================

sst = sst.sel(
    lat=slice(0, 30),
    lon=slice(300, 350)
)

sst = sst.sel(
    lat=p90.lat,
    lon=p90.lon
)

sst = sst.transpose("time", "lat", "lon")
p90 = p90.transpose("dayofyear", "lat", "lon")

print("SST shape:", sst.shape)
print("P90 shape:", p90.shape)

# =============================
# 5. Match daily P90 to SST dates
# =============================

sst = sst.assign_coords(
    dayofyear=sst["time"].dt.dayofyear
)

p90_for_year = p90.sel(
    dayofyear=sst["dayofyear"]
)

p90_for_year = p90_for_year.assign_coords(
    time=sst["time"]
)

p90_for_year = p90_for_year.transpose("time", "lat", "lon")

# =============================
# 6. Daily exceedance
# =============================

above_p90 = (sst > p90_for_year).compute()

# =============================
# 7. Detect MHW days >= 5 consecutive days
# =============================

def detect_mhw_1d(arr):
    arr = np.asarray(arr)
    arr = np.nan_to_num(arr, nan=False).astype(bool)

    result = np.zeros_like(arr, dtype=bool)

    n = len(arr)
    i = 0

    while i < n:
        if arr[i]:
            start = i

            while i < n and arr[i]:
                i += 1

            end = i

            if end - start >= 5:
                result[start:end] = True
        else:
            i += 1

    return result


print("Detecting MHW days...")

mhw_days = xr.apply_ufunc(
    detect_mhw_1d,
    above_p90,
    input_core_dims=[["time"]],
    output_core_dims=[["time"]],
    vectorize=True,
    output_dtypes=[bool]
)

mhw_days = mhw_days.transpose("time", "lat", "lon")

print("MHW days detected.")

# =============================
# 8. Count distinct annual MHW events
# =============================

def count_events_1d(arr):
    arr = np.asarray(arr)
    arr = np.nan_to_num(arr, nan=False).astype(bool)

    if arr.size == 0:
        return 0

    padded = np.concatenate([[False], arr])
    starts = np.diff(padded.astype(int)) == 1

    return int(starts.sum())


print("Counting annual MHW events...")

annual_mhw_frequency = xr.apply_ufunc(
    count_events_1d,
    mhw_days,
    input_core_dims=[["time"]],
    vectorize=True,
    output_dtypes=[int]
)

print("Annual MHW frequency calculated.")

# =============================
# 9. Print summary statistics
# =============================

max_frequency = int(annual_mhw_frequency.max())
mean_frequency = float(annual_mhw_frequency.mean())
total_gridcell_events = int(annual_mhw_frequency.sum())

print("=================================")
print(f"Annual MHW Frequency Summary: {year}")
print("=================================")
print(f"Maximum events in one grid cell: {max_frequency}")
print(f"Mean events per grid cell: {mean_frequency:.2f}")
print(f"Total grid-cell events: {total_gridcell_events}")
print("Note: Total grid-cell events is not basin-wide event count.")
print("It is the sum of events across all grid cells.")

# =============================
# 10. Plot annual MHW frequency map
# =============================

fig = plt.figure(figsize=(10, 6))
ax = plt.axes(projection=ccrs.PlateCarree())

pcm = annual_mhw_frequency.plot(
    ax=ax,
    transform=ccrs.PlateCarree(),
    cmap="hot_r",
    add_colorbar=False,
    vmin=0,
    vmax=max_frequency
)

ax.coastlines()
ax.add_feature(cfeature.LAND, facecolor="lightgray")

gl = ax.gridlines(draw_labels=True)
gl.top_labels = False
gl.right_labels = False

cbar = plt.colorbar(
    pcm,
    ax=ax,
    orientation="horizontal",
    pad=0.08,
    fraction=0.05
)

cbar.set_label("Number of MHW Events")

plt.title(
    f"Annual Marine Heatwave Frequency Based on Daily SST > Daily P90 ({year})"
)

plt.tight_layout()
plt.show()